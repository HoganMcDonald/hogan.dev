---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import Prose from '../components/Prose.astro';

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags?: string[];
}

const { title, date, excerpt, tags } = Astro.props;
---

<BaseLayout title={title} description={excerpt}>
  <article class="py-8">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-fg-bright">{title}</h1>
      <div class="mt-4">
        <PostMeta date={date} tags={tags} />
      </div>
    </header>
    <Prose>
      <slot />
    </Prose>
  </article>
</BaseLayout>
