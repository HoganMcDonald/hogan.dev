<header class="sticky top-0 z-50 border-b border-white/8 bg-bg/40 backdrop-blur-2xl backdrop-saturate-150 shadow-lg shadow-black/20">
  <nav class="mx-auto flex max-w-2xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-bold text-yellow hover:text-orange transition-colors">
      hogan.dev
    </a>
    <div class="flex gap-6">
      <a href="/" class="nav-link relative text-fg hover:text-fg-bright transition-colors">Blog</a>
      <a href="/rss.xml" class="nav-link relative text-fg hover:text-fg-bright transition-colors">RSS</a>
    </div>
  </nav>
</header>

<style>
  @reference "../styles/global.css";

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--color-cyan);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s ease;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }
</style>
