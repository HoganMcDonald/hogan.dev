---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found">
  <div class="flex flex-col items-center justify-center py-32 text-center">
    <h1 class="text-6xl font-bold text-yellow">404</h1>
    <p class="mt-4 text-xl text-fg">Page not found.</p>
    <a href="/" class="mt-8 text-cyan hover:text-orange transition-colors">
      Back home
    </a>
  </div>
</BaseLayout>
